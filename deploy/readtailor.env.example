# Runtime environment installed as /etc/readtailor/readtailor.env.
# Keep values shell-free: one KEY=value entry per line.
NODE_ENV=production

DATABASE_URL=postgresql://<user>:<password>@<host>:5432/readtailor
REDIS_URL=rediss://default:<password>@<host>:6379

OBJECT_STORAGE_ENDPOINT=https://<endpoint>
OBJECT_STORAGE_REGION=<region>
OBJECT_STORAGE_BUCKET=<bucket>
OBJECT_STORAGE_ACCESS_KEY_ID=<access-key-id>
OBJECT_STORAGE_SECRET_ACCESS_KEY=<secret-access-key>
OBJECT_STORAGE_FORCE_PATH_STYLE=true
OBJECT_STORAGE_LOCAL_ROOT=

MODEL_API_BASE_URL=https://<model-endpoint>
MODEL_API_KEY=<model-api-key>
MODEL_NAME=<model-name>

SANDBOX_PROVIDER=ppio
PPIO_API_KEY=<ppio-api-key>
PPIO_DOMAIN=sandbox.ppio.cn
PPIO_TEMPLATE=
E2B_API_KEY=
E2B_DOMAIN=e2b.dev
E2B_TEMPLATE=

NORMALIZATION_MAX_ATTEMPTS=3
NORMALIZATION_MAX_TURNS=50
NORMALIZATION_ATTEMPT_TIMEOUT_MS=1800000
BOOK_ANALYSIS_MAX_TURNS=20
BOOK_ANALYSIS_TIMEOUT_MS=1200000

API_HOST=127.0.0.1
API_PORT=3001
WEB_ORIGINS=https://readtailor.narcissus.life
WEB_BASE_URL=https://readtailor.narcissus.life
LOG_LEVEL=info

AUTH_COOKIE_SECRET=<openssl-rand-hex-32>
AUTH_COOKIE_SECURE=true
AUTH_SESSION_DAYS=30
AUTH_DEVELOPMENT_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://readtailor.narcissus.life/v1/auth/google/callback
SYSTEM_API_TOKEN=<openssl-rand-hex-32>

WORKER_HOST=127.0.0.1
WORKER_PORT=3002
WORKER_CONCURRENCY=1
SYSTEM_CONCURRENCY=1
NORMALIZATION_CONCURRENCY=1
CONTENT_GENERATION_CONCURRENCY=1
WORKER_QUEUES=system,normalization,content-generation
