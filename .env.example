# Shared cloud services. Use separate resources or databases for local testing and production.
DATABASE_URL=postgresql://user:password@host:5432/readtailor
REDIS_URL=rediss://default:password@host:6379
OBJECT_STORAGE_ENDPOINT=https://s3.example.com
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_BUCKET=readtailor
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
# To use filesystem storage locally, clear OBJECT_STORAGE_BUCKET and set this path.
OBJECT_STORAGE_LOCAL_ROOT=

# Model engine (OpenAI-compatible chat completions endpoint).
# These are the global defaults. Every AI feature below can override any of the
# three (base URL / key / model) independently; whatever it doesn't set falls
# back to these. Leave all three empty to run that feature on the fake engine.
MODEL_API_BASE_URL=https://api.example.com
MODEL_API_KEY=
MODEL_NAME=

# Per-feature model overrides. Each accepts _MODEL_API_BASE_URL, _MODEL_API_KEY
# and _MODEL_NAME; any unset field falls back to the global MODEL_* above.
#   SYSTEM_CHAT_*        — /v1/system chat (API)
#   READING_SETUP_*      — interview → strategy → trial engine (API)
#   CONTENT_GENERATION_* — 裁读 content generation (Worker)
#   NORMALIZATION_*      — formal EPUB normalization agent (Worker)
#   BOOK_ANALYSIS_*      — book profile analysis agent (Worker); if unset it
#                          inherits NORMALIZATION_* before the global MODEL_*.
# Example: point book analysis at a cheaper model on the same provider —
#   BOOK_ANALYSIS_MODEL_NAME=some-cheaper-model
# Example: send system chat to a different provider entirely —
#   SYSTEM_CHAT_MODEL_API_BASE_URL=https://other.example.com
#   SYSTEM_CHAT_MODEL_API_KEY=...
#   SYSTEM_CHAT_MODEL_NAME=...

# Formal EPUB normalization (Worker-hosted Pi Agent + E2B)
E2B_API_KEY=
# Optional custom E2B template with Python and beautifulsoup4 preinstalled.
E2B_TEMPLATE=
NORMALIZATION_MODEL_NAME=
NORMALIZATION_MAX_ATTEMPTS=3
NORMALIZATION_MAX_TURNS=50
NORMALIZATION_ATTEMPT_TIMEOUT_MS=1800000
BOOK_ANALYSIS_MODEL_NAME=
BOOK_ANALYSIS_MAX_TURNS=20
BOOK_ANALYSIS_TIMEOUT_MS=1200000

# API
API_HOST=0.0.0.0
API_PORT=3001
WEB_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
WEB_BASE_URL=http://localhost:5173
LOG_LEVEL=info

# Authentication. Email/password works when DATABASE_URL and AUTH_COOKIE_SECRET are configured.
# Generate AUTH_COOKIE_SECRET with: openssl rand -hex 32
AUTH_COOKIE_SECRET=
AUTH_COOKIE_SECURE=false
AUTH_SESSION_DAYS=30
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/v1/auth/google/callback
# Local-only escape hatch. Never enable in production.
AUTH_DEVELOPMENT_ENABLED=false

# Protects /v1/system/* diagnostics. Use a separate high-entropy token.
SYSTEM_API_TOKEN=

# Worker
WORKER_HOST=0.0.0.0
WORKER_PORT=3002
# Base per-queue concurrency. Each queue below defaults to this unless overridden.
WORKER_CONCURRENCY=1
# Per-queue overrides. Content generation is light LLM I/O and defaults to 5 (runs a trial's
# three segments in parallel); normalization is heavy (E2B sandbox) so keep it at the base.
#   SYSTEM_CONCURRENCY=1
#   NORMALIZATION_CONCURRENCY=1
#   CONTENT_GENERATION_CONCURRENCY=5
# Which queue consumers this process runs (comma-separated). Defaults to all three. Use it to
# run dedicated pools, e.g. WORKER_QUEUES=content-generation for a generation-only fleet.
#   WORKER_QUEUES=system,normalization,content-generation

# Web
VITE_API_BASE_URL=http://localhost:3001
VITE_AUTH_DEVELOPMENT_ENABLED=false
